# ============================================================
# DISCORD SAAS BACKEND — ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in all values before starting
# ============================================================

# ── Server ────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# ── Security ──────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string_min_64_chars
JWT_EXPIRES_IN=7d
ENCRYPTION_KEY=32_byte_hex_key_for_aes_256_change_me_now_please
ENCRYPTION_IV=16_byte_hex_iv_change_this_now

# ── Database ──────────────────────────────────────────────
DATABASE_PATH=./data/discord_saas.db

# ── CORS ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
BACKEND_PUBLIC_URL=http://localhost:4000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# â”€â”€ Email Security / Verification â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=DiscordForger Security
AUTH_REQUIRE_EMAIL_VERIFICATION=true
AUTH_REQUIRE_LOGIN_APPROVAL_NEW_DEVICE=true
AUTH_REQUIRE_ALLOWED_EMAIL_DOMAIN=true
AUTH_LOOKUP_LOGIN_LOCATION=true
AUTH_VERIFICATION_TTL_MINUTES=30
AUTH_LOGIN_APPROVAL_TTL_MINUTES=20
# Example allowlist. Add your own if needed.
AUTH_ALLOWED_EMAIL_DOMAINS=gmail.com,googlemail.com,outlook.com,hotmail.com,live.com,orange.fr,orange.com,yahoo.com,yahoo.fr,icloud.com,free.fr,laposte.net,sfr.fr,bbox.fr,bouyguestelecom.fr,proton.me,protonmail.com
AUTH_BLOCKED_EMAIL_DOMAINS=mailinator.com,guerrillamail.com,10minutemail.com,temp-mail.org,yopmail.com,mail.tm
AUTH_GEOLOOKUP_ENDPOINT=https://ipwho.is/{ip}

# ── Discord OAuth ─────────────────────────────────────────
DISCORD_CLIENT_ID=your_discord_oauth_client_id
DISCORD_CLIENT_SECRET=your_discord_oauth_client_secret
DISCORD_CALLBACK_URL=http://localhost:4000/api/v1/auth/discord/callback

# ── Google OAuth ──────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=20

# ── Bot Runtime ───────────────────────────────────────────
BOT_MAX_RESTART_ATTEMPTS=5
BOT_RESTART_DELAY_MS=5000
BOT_RESTART_BACKOFF_MULTIPLIER=2

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs
LOG_MAX_FILES=14d
LOG_MAX_SIZE=20m

# ── AI (Admin configures via panel, these are defaults) ───
DEFAULT_AI_PROVIDER=anthropic
DEFAULT_AI_MODEL=claude-sonnet-4-20250514

# ── Optional: Redis for job queues ────────────────────────
# Leave blank to use in-memory queue fallback
REDIS_URL=

# ── Founder Account (auto-created on first run) ───────────
FOUNDER_USERNAME=Founder
FOUNDER_EMAIL=founder@example.com
FOUNDER_PASSWORD=ChangeMe123!
